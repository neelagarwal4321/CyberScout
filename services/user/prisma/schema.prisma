// Domain subset for user-service (identity layer only).
// Canonical full-platform schema: packages/db/schema.prisma
// To update: edit packages/db/schema.prisma then run: make sync-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum subscription_tier {
  free
  beginner
  intermediate
  pro
}

enum subscription_status {
  active
  cancelled
  past_due
  expired
}

model users {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  google_id     String              @unique @db.VarChar(255)
  email         String              @unique @db.VarChar(255)
  name          String              @db.VarChar(255)
  avatar_url    String?
  tier          subscription_tier   @default(free)
  xp_total      Int                 @default(0)
  level         Int                 @default(1) @db.SmallInt
  is_active     Boolean             @default(true)
  created_at    DateTime            @default(now()) @db.Timestamptz()
  last_login_at DateTime?           @db.Timestamptz()
  deleted_at    DateTime?           @db.Timestamptz()
  subscriptions subscriptions?
}

model subscriptions {
  id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id              String              @unique @db.Uuid
  tier                 subscription_tier   @default(free)
  status               subscription_status @default(active)
  razorpay_sub_id      String?             @unique @db.VarChar(255)
  current_period_start DateTime?           @db.Timestamptz()
  current_period_end   DateTime?           @db.Timestamptz()
  cancel_at_period_end Boolean             @default(false)
  created_at           DateTime            @default(now()) @db.Timestamptz()
  updated_at           DateTime            @default(now()) @db.Timestamptz()
  users                users               @relation(fields: [user_id], references: [id], onDelete: Cascade)
}
