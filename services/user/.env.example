# User Service — required environment variables
# Copy to .env and fill in real values. Never commit .env to git.

NODE_ENV=development
PORT=3002

# PostgreSQL
DATABASE_URL=postgresql://cyberscout:localdevpassword@localhost:5432/cyberscout_db

# Redis
REDIS_URL=redis://:localredispass@localhost:6379

# RSA JWT public key (file path — shared with auth service)
JWT_PUBLIC_KEY_FILE=../../infra/secrets/jwt_public.pem
