generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql"; url = env("DATABASE_URL") }
enum subscription_tier { free; beginner; intermediate; pro }
model users { id String @id @db.Uuid; live_classes live_classes[] @relation("Instructor"); zoom_sessions zoom_sessions[]; class_registrations class_registrations[] }
model live_classes { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid; title String @db.VarChar(500); description String?; zoom_meeting_id String @unique @db.VarChar(100); zoom_join_url String; zoom_password String? @db.VarChar(100); tier_required subscription_tier @default(beginner); instructor_user_id String @db.Uuid; starts_at DateTime @db.Timestamptz(); duration_mins Int; max_participants Int?; is_published Boolean @default(false); recording_r2_key String?; created_at DateTime @default(now()) @db.Timestamptz(); instructor users @relation("Instructor", fields: [instructor_user_id], references: [id]); zoom_sessions zoom_sessions[]; class_registrations class_registrations[] }
model zoom_sessions { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid; user_id String @db.Uuid; class_id String @db.Uuid; zoom_participant_id String? @db.VarChar(100); joined_at DateTime? @db.Timestamptz(); left_at DateTime? @db.Timestamptz(); duration_mins Int?; xp_earned Int @default(0); attendance_valid Boolean @default(false); users users @relation(fields: [user_id], references: [id]); live_classes live_classes @relation(fields: [class_id], references: [id]) }
model class_registrations { user_id String @db.Uuid; class_id String @db.Uuid; registered_at DateTime @default(now()) @db.Timestamptz(); reminder_sent Boolean @default(false); users users @relation(fields: [user_id], references: [id]); live_classes live_classes @relation(fields: [class_id], references: [id]); @@id([user_id, class_id]) }
