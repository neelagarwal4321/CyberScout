# Auth Service — required environment variables
# Copy to .env and fill in real values. Never commit .env to git.

NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://cyberscout:localdevpassword@localhost:5432/cyberscout_db

# Redis
REDIS_URL=redis://:localredispass@localhost:6379

# RSA JWT keys (file paths — generate with: make keys)
JWT_PRIVATE_KEY_FILE=../../infra/secrets/jwt_private.pem
JWT_PUBLIC_KEY_FILE=../../infra/secrets/jwt_public.pem

# Google OAuth2 — get from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback
