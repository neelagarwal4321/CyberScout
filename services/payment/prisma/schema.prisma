generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql"; url = env("DATABASE_URL") }
enum subscription_tier { free; beginner; intermediate; pro }
enum subscription_status { active; cancelled; past_due; expired }
model users { id String @id @db.Uuid; payments payments[]; subscriptions subscriptions? }
model subscriptions { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid; user_id String @unique @db.Uuid; tier subscription_tier @default(free); status subscription_status @default(active); razorpay_sub_id String? @unique @db.VarChar(255); current_period_start DateTime? @db.Timestamptz(); current_period_end DateTime? @db.Timestamptz(); cancel_at_period_end Boolean @default(false); created_at DateTime @default(now()) @db.Timestamptz(); updated_at DateTime @default(now()) @db.Timestamptz(); users users @relation(fields: [user_id], references: [id]) }
model payments { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid; user_id String @db.Uuid; subscription_id String? @db.Uuid; razorpay_order_id String? @unique @db.VarChar(255); razorpay_payment_id String? @unique @db.VarChar(255); amount_paise Int; currency String @default("INR") @db.VarChar(5); status String @default("pending") @db.VarChar(20); tier_purchased subscription_tier?; billing_period String @default("monthly") @db.VarChar(10); idempotency_key String @unique @db.VarChar(255); razorpay_event_payload Json?; created_at DateTime @default(now()) @db.Timestamptz(); users users @relation(fields: [user_id], references: [id]) }
