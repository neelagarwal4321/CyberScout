generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql"; url = env("DATABASE_URL") }
model users { id String @id @db.Uuid; email String @db.VarChar(255); name String @db.VarChar(255); notifications notifications[]; email_log email_log[] }
model notifications { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid; user_id String @db.Uuid; type String @db.VarChar(50); title String @db.VarChar(255); body String; reference_id String? @db.Uuid; is_read Boolean @default(false); sent_at DateTime? @db.Timestamptz(); created_at DateTime @default(now()) @db.Timestamptz(); users users @relation(fields: [user_id], references: [id]) }
model email_log { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid; user_id String @db.Uuid; template String @db.VarChar(100); to_email String @db.VarChar(255); subject String @db.VarChar(500); brevo_msg_id String? @unique @db.VarChar(255); status String @default("queued") @db.VarChar(20); sent_at DateTime? @db.Timestamptz(); created_at DateTime @default(now()) @db.Timestamptz(); users users @relation(fields: [user_id], references: [id]) }
