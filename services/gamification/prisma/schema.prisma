generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum subscription_tier {
  free
  beginner
  intermediate
  pro
}

model users {
  id                String              @id @db.Uuid
  xp_total          Int                 @default(0)
  level             Int                 @default(1) @db.SmallInt
  tier              subscription_tier   @default(free)
  xp_ledger         xp_ledger[]
  user_achievements user_achievements[]
}

model xp_ledger {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String   @db.Uuid
  delta        Int
  reason       String   @db.VarChar(100)
  reference_id String?  @db.Uuid
  balance_after Int
  created_at   DateTime @default(now()) @db.Timestamptz()
  users        users    @relation(fields: [user_id], references: [id])
}

model achievements {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug              String              @unique @db.VarChar(100)
  name              String              @db.VarChar(255)
  description       String?
  icon_r2_key       String?
  xp_bonus          Int                 @default(0)
  trigger_type      String              @db.VarChar(50)
  trigger_value     Int?
  unlock_type       String              @db.VarChar(50)
  unlock_value      String?             @db.VarChar(255)
  is_active         Boolean             @default(true)
  user_achievements user_achievements[]
}

model user_achievements {
  user_id        String       @db.Uuid
  achievement_id String       @db.Uuid
  earned_at      DateTime     @default(now()) @db.Timestamptz()
  notified_at    DateTime?    @db.Timestamptz()
  xp_credited    Int          @default(0)
  users          users        @relation(fields: [user_id], references: [id])
  achievements   achievements @relation(fields: [achievement_id], references: [id])

  @@id([user_id, achievement_id])
  @@unique([user_id, achievement_id])
}
