# Database
DATABASE_URL="postgresql://cyberscout:password@localhost:5432/cyberscout_db"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Inter-service HMAC
INTERNAL_HMAC_SECRET="change-me-internal-hmac-secret"

# Anthropic (Chat service)
ANTHROPIC_API_KEY="sk-ant-..."

# OpenAI (Embeddings)
OPENAI_API_KEY="sk-..."

# Pinecone (Vector store)
PINECONE_API_KEY="..."
PINECONE_ENVIRONMENT="..."
PINECONE_INDEX="cyberscout-knowledge"

# Stripe (Billing service)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_MAX_MONTHLY="price_..."
STRIPE_PRICE_PRO_YEARLY="price_..."
STRIPE_PRICE_MAX_YEARLY="price_..."

# Google OAuth
GOOGLE_CLIENT_ID="..."

# Apple OAuth
APPLE_CLIENT_ID="..."
APPLE_KEY_ID="..."
APPLE_TEAM_ID="..."

# Service ports
PORT_GATEWAY=3000
PORT_AUTH=3001
PORT_COURSE=3002
PORT_CHAT=3003
PORT_BILLING=3004
PORT_LIVE=3005
PORT_MENTOR=3006

# Environment
NODE_ENV="development"
